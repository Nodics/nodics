{
    "name": "nodics",
    "version": "0.0.1",
    "index": "0",
    "description": "Nodics, A Node based enterprise application solution",
    "main": "nodics.js",
    "scripts": {
        "test": "npm run test:basic",
        "test:basic": "npm run check:syntax && npm run test:config && npm run test:traceability && npm run test:headers && npm run test:route-contracts && npm run test:generated && npm run test:system && npm run test:import && npm run test:profile && npm run test:ems",
        "test:full": "npm run test:basic && npm run test:topology",
        "test:traceability": "npm run test:error-traceability && npm run test:execution-layer-traceability",
        "test:headers": "npm run test:auth-headers && npm run test:module-headers",
        "test:route-contracts": "node scripts/run-route-contract-tests.js",
        "test:generated": "node scripts/run-generated-tests.js",
        "test:generated-schema": "node scripts/run-generated-tests.js --type=schema",
        "test:generated-api": "node scripts/run-generated-tests.js --type=api",
        "test:generated-api-scenarios": "node scripts/run-generated-tests.js --type=apiScenario",
        "test:generated-crud": "node scripts/run-generated-tests.js --type=crud",
        "test:generated-crud-live": "node scripts/run-generated-crud-live-tests.js",
        "test:system": "node scripts/run-capability-behavior-tests.js --area=system",
        "test:import": "npm run test:import-validation && npm run test:core-sample-data-catalog && npm run test:import-formats && npm run test:import-diagnostics && npm run test:duplicate-header-diagnostics && npm run test:finalized-record-counter && npm run test:finalized-import-dispatch && npm run test:import-failure-traceability",
        "test:profile": "npm run test:profile-init-flag && npm run test:profile-init-required && node scripts/run-capability-behavior-tests.js --area=profile",
        "test:capability-behavior": "node scripts/run-capability-behavior-tests.js",
        "test:ems": "npm run test:ems-message-tenant && node scripts/run-capability-behavior-tests.js --area=ems",
        "test:ems-publish": "node gFramework/nEms/emsClient/test/activeEmsPublisher.test.js",
        "test:topology": "npm run test:kickoff-topology",
        "test:config": "node gFramework/nConfig/test/configurationValidation.test.js",
        "test:error-traceability": "node gFramework/nCommon/test/errorTraceability.test.js",
        "test:execution-layer-traceability": "node gFramework/nCommon/test/executionLayerTraceability.test.js",
        "test:auth-headers": "node gFramework/nRouter/test/authHeaderNormalization.test.js",
        "test:module-headers": "node gFramework/nService/test/moduleRequestHeaderNormalization.test.js",
        "test:import-validation": "node gFramework/nData/nImport/import/test/systemDataImportInitializerValidation.test.js",
        "test:core-sample-data-catalog": "node gFramework/nData/nImport/import/test/systemCoreSampleDataCatalog.test.js",
        "test:import-formats": "node gFramework/nData/nImport/import/test/multiFormatDataProcessors.test.js",
        "test:import-diagnostics": "node gFramework/nData/nImport/import/test/systemImportDiagnosticsValidationOnly.test.js",
        "test:duplicate-header-diagnostics": "node gFramework/nData/nImport/import/test/importDuplicateHeaderDiagnostics.test.js",
        "test:finalized-record-counter": "node gFramework/nData/nImport/import/test/finalizedRecordCounter.test.js",
        "test:finalized-import-dispatch": "node gFramework/nData/nImport/import/test/finalizedImportDispatch.test.js",
        "test:import-failure-traceability": "node gFramework/nData/nImport/import/test/importFailureTraceability.test.js",
        "test:kickoff-topology": "node kickoff/test/topology/kickoffLocalRuntimeTopology.test.js",
        "test:profile-init-flag": "node gCore/profile/test/initRequiredFlag.test.js",
        "test:profile-init-required": "node gCore/profile/test/profileInitRequiredDetection.test.js",
        "test:profile-routes": "node gCore/profile/test/profileRouteContract.test.js",
        "test:cronjob-routes": "node gCore/cronjob/test/cronJobRouteContract.test.js",
        "test:system-routes": "node gFramework/nSystem/test/systemRouteContract.test.js",
        "test:ems-client-routes": "node gFramework/nEms/emsClient/test/emsClientRouteContract.test.js",
        "test:workflow-routes": "node gCore/workflow/flowApi/test/workflowRouteContract.test.js",
        "test:search-routes": "node gFramework/nSearch/search/test/searchRouteContract.test.js",
        "test:dynamo-routes": "node gFramework/nDynamo/test/dynamoRouteContract.test.js",
        "test:ems-message-tenant": "node gFramework/nEms/emsClient/test/messageTenantResolution.test.js",
        "check:syntax": "find . -name '*.js' -not -path './node_modules/*' -print0 | xargs -0 -n 50 node --check",
        "generate:app": "node -e 'require(\"./nodics\").genApp()'",
        "generate:group": "node -e 'require(\"./nodics\").genGroup()'",
        "generate:module": "node -e 'require(\"./nodics\").genModule()'",
        "generate:module:react": "node -e 'require(\"./nodics\").genReactModule()'",
        "generate:module:vue": "node -e 'require(\"./nodics\").genVueModule()'",
        "app": "node -e 'require(\"./nodics\").genApp()'",
        "group": "node -e 'require(\"./nodics\").genGroup()'",
        "module": "node -e 'require(\"./nodics\").genModule()'",
        "module:react": "node -e 'require(\"./nodics\").genReactModule()'",
        "module:vue": "node -e 'require(\"./nodics\").genVueModule()'",
        "clean": "node -e 'require(\"./nodics\").cleanAll()'",
        "clean:debug": "node scripts/nodics-debug.js clean --brk",
        "clean:inspect": "node scripts/nodics-debug.js clean --no-brk",
        "cleanDebug": "node scripts/nodics-debug.js clean --brk",
        "build": "node -e 'require(\"./nodics\").buildAll()'",
        "build:debug": "node scripts/nodics-debug.js build --brk",
        "build:inspect": "node scripts/nodics-debug.js build --no-brk",
        "buildDebug": "node scripts/nodics-debug.js build --brk",
        "start": "node -e 'require(\"./nodics\").start()'",
        "start:debug": "node scripts/nodics-debug.js start --brk",
        "start:inspect": "node scripts/nodics-debug.js start --no-brk",
        "debug": "node scripts/nodics-debug.js start --brk"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nodics/nodics.git"
    },
    "keywords": [
        "Nodics",
        "Nodics",
        "Framework",
        "Micro-Services"
    ],
    "author": "Nodics Framework <nodics.framework@gmail.com>",
    "license": "GPL-3.0-or-later",
    "bugs": {
        "url": "https://github.com/Nodics/nodics/issues"
    },
    "homepage": "https://github.com/Nodics/nodics#readme",
    "dependencies": {
        "@elastic/elasticsearch": "^8.0.0",
        "bcryptjs": "^2.4.3",
        "body-parser": "^1.19.2",
        "chai": "^4.3.6",
        "clear-module": "^4.1.2",
        "convert-excel-to-json": "^1.7.0",
        "cron": "^1.8.2",
        "csvtojson": "^2.0.10",
        "email-validator": "^2.0.4",
        "excel-as-json2": "^0.4.0",
        "express": "^4.17.3",
        "flatted": "^3.2.7",
        "fs-extra": "^10.0.1",
        "jsonwebtoken": "^9.0.3",
        "kafkajs": "^2.2.4",
        "lodash": "^4.17.21",
        "logform": "^2.4.0",
        "mocha": "^9.2.1",
        "mocha-suit": "^0.8.5",
        "mongodb": "4.9",
        "node-cache": "^5.1.2",
        "node-fetch": "^2.6.7",
        "object-sizeof": "^1.6.3",
        "recursive-copy": "^2.0.14",
        "redis": "^4.0.4",
        "require-from-string": "^2.0.2",
        "should": "^13.2.3",
        "stompit": "^1.0.0",
        "stream-json": "^1.7.4",
        "uuid": "^8.3.2",
        "winston": "^3.6.0",
        "winston-elasticsearch": "^0.16.1",
        "xml-js": "^1.6.11"
    }
}
